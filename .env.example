BOT_TOKEN=
TINVEST_TOKEN=
OWNER_CHAT_ID=
TINVEST_ACCOUNT_ID=
TARGET_FILE=./target.yaml
LOG_LEVEL=INFO

# Optional. Route only Telegram API traffic through a proxy (T-Invest goes direct).
# Useful when the server's IP can't reach api.telegram.org (e.g. RU hosting).
# Supported schemes: http, https, socks4, socks5. SOCKS5 already resolves DNS via
# the proxy. IPv6 hosts MUST be wrapped in square brackets.
# Examples:
#   TELEGRAM_PROXY_URL=socks5://user:pass@1.2.3.4:1080
#   TELEGRAM_PROXY_URL=socks5://user:pass@[2001:db8::1]:1080
#   TELEGRAM_PROXY_URL=http://user:pass@proxy.example.com:3128
TELEGRAM_PROXY_URL=
